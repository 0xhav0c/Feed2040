# ╔═══════════════════════════════════════════════════════╗
# ║            Feed2040 Configuration                    ║
# ╚═══════════════════════════════════════════════════════╝
# Copy this file to .env and fill in the values.
# Only NEXTAUTH_SECRET is required to change for production.

# ── Database ──────────────────────────────────────────────
POSTGRES_USER=feed2040
POSTGRES_PASSWORD=feed2040
POSTGRES_DB=feed2040

# ── Application ───────────────────────────────────────────
APP_PORT=3000
NEXTAUTH_URL=http://localhost:3000
# REQUIRED: Generate a secure secret with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# ── Feed Refresh ──────────────────────────────────────────
REFRESH_INTERVAL_MINUTES=15

# REQUIRED: Generate a strong secret with:
#   openssl rand -hex 24
CRON_SECRET=

# ── Optional: AI & Telegram ───────────────────────────────
# These can be configured through the Settings UI instead.
# If you prefer .env, uncomment and fill in:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
